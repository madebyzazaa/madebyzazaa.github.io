<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>login</title>
</head>
<style>
body{
background-color: rgb(247, 247, 247);
}
h1{
font-family: sans-serif;
font-size: clamp(2rem, 4vw, 5rem);
text-align: center;
margin-top: 50px;
text-transform: uppercase;
color: rgb(0, 0, 0);
}
input{
width: 100%;
height: 40px;
border: 0;
border-radius: 7px;
padding-left: 10px;
}
#submit{
width: 100%;
height: 40px;
border-radius: 10px;
background-color: rgb(25, 25, 36);
color: white;
margin-top: 50px;
border: 0;
}
.form{
width: 20%;
min-width: 290px;
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
row-gap: 25px;
margin-left: auto;
margin-right: auto;
height: 65vh;
}
@media (max-width: 350px) {
.form{
width: 90%;
min-width: 100px;
}
}
</style>
<body>
    <main>
        <h1>fresh universe</h1>
        <form action="/admin/signin" method="post" class="form">
            <input type="text" name="admin" id="admin" placeholder="<%= text %>" required>
            <input type="password" name="password" id="password" placeholder="password" required>
            <button id="submit" type="submit">verify</button>
        </form>
    </main>
</body>
</html>